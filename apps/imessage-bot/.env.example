# Privy
PRIVY_APP_ID=your-app-id
PRIVY_APP_SECRET=your-app-secret

# Treasury (optional — for funding user wallets)
TREASURY_WALLET_ID=your-treasury-wallet-id
TREASURY_ADDRESS=0x...

# MPP service — swap URL + model to use any MPP-compatible service
# Public OpenAI proxy:
#   MPP_SERVICE_URL=https://openai.mpp.tempo.xyz/v1/chat/completions
#   MPP_MODEL=gpt-4o
# Local Venice AI proxy (run apps/mpp-service first):
#   MPP_SERVICE_URL=http://localhost:3001/venice/v1/chat/completions
#   MPP_MODEL=deepseek-r1-671b
MPP_SERVICE_URL=http://localhost:3001/venice/v1/chat/completions
MPP_MODEL=deepseek-r1-671b

# Bot
BOT_PHONE=+1234567890

# Database (optional — defaults to imessage-pay.db in working directory)
# DB_PATH=imessage-pay.db
