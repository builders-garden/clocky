# Venice AI API key — injected as Bearer token into upstream requests
VENICE_API_KEY=

# Secret key for MPP session signing (generate with: openssl rand -hex 32)
# Required for production; if absent, Mppx generates a temporary key (sessions won't survive restarts)
MPP_SECRET_KEY=

# Your Tempo wallet address — receives MPP payments from clients
RECIPIENT_ADDRESS=0x...

# USDC token contract address on Tempo mainnet
# Use 0x20c0000000000000000000000000000000000000 (PathUSD) for testnet
PAYMENT_CURRENCY=0x20C000000000000000000000b9537d11c60E8b50

# Port to listen on (default: 3001 — avoids conflict with other local services)
PORT=3001
